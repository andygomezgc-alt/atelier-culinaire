# ── Database ────────────────────────────────────────────────────────────────
# Local dev: use Docker (see docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/atelier"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ── Vercel Blob (required in production for file uploads) ────────────────────
# Get from Vercel dashboard → Storage → Blob → your store → .env.local
# Leave empty in dev to fall back to local public/uploads/
BLOB_READ_WRITE_TOKEN=""

# ── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Seed bootstrap account ───────────────────────────────────────────────────
SEED_CHEF_EMAIL="chef@ristorantemarche.it"
SEED_CHEF_PASSWORD="atelier2026"
